                ],
                "properties": {
                    "cod_assunto": {
                        "description": "Código do assunto",
                        "type": "integer",
                        "example": 1
                    },
                    "descricao": {
                        "description": "Descrição do assunto",
                        "type": "string",
                        "example": "Literatura Brasileira"
                    },
                    "livros": {
                        "description": "Lista de livros relacionados ao assunto",
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "type": "object"
            },
            "Autor": {
                "title": "Autor",
                "description": "Modelo de Autor",
                "required": [
                    "nome"
                ],
                "properties": {
                    "cod_autor": {
                        "description": "Código do autor",
                        "type": "integer",
                        "example": 1
                    },
                    "nome": {
                        "description": "Nome do autor",
                        "type": "string",
                        "example": "Machado de Assis"
                    },
                    "livros": {
                        "description": "Lista de livros do autor",
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "type": "object"
            },
            "Livro": {
                "title": "Livro",
                "description": "Modelo de Livro",
                "required": [
                    "titulo",
                    "editora",
                    "ano_publicacao",
                    "valor"
                ],
                "properties": {
                    "cod_livro": {
                        "description": "Código do livro",
                        "type": "integer",
                        "example": 1
                    },
                    "titulo": {
                        "description": "Título do livro",
                        "type": "string",
                        "example": "Dom Casmurro"
                    },
                    "editora": {
                        "description": "Editora do livro",
                        "type": "string",
                        "example": "Editora Globo"
                    },
                    "edicao": {
                        "description": "Número da edição",
                        "type": "integer",
                        "example": 2
                    },
                    "ano_publicacao": {
                        "description": "Ano de publicação",
                        "type": "string",
                        "example": 1899
                    },
                    "valor": {
                        "description": "Valor do livro",
                        "type": "number",
                        "format": "float",
                        "example": 39.9
                    },
                    "autores": {
                        "description": "Lista de autores",
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "assuntos": {
